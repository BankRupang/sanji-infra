# ============================================================================
# prod 환경 변수 값 예시 파일
# ============================================================================
# 사용법:
#   1) 이 파일을 terraform.tfvars 라는 이름으로 복사합니다.
#        cp terraform.tfvars.example terraform.tfvars
#   2) 아래 값을 우리 환경에 맞게 채웁니다.
#   3) terraform.tfvars 는 비밀번호가 들어가므로 git에 올리지 않습니다.
#      (.gitignore가 *.tfvars 를 이미 제외하고 있습니다. 이 .example만 추적됩니다.)

# --- 공통 ---
project     = "sanji"
environment = "prod"
aws_region  = "ap-northeast-2"

# --- 네트워크 ---
# Grafana/SSH 접근을 허용할 본인 공인 IP로 꼭 좁히세요. (예: "1.2.3.4/32")
admin_cidr = "0.0.0.0/0"

# --- 데이터베이스 (필수) ---
db_name     = "sanji"
db_username = "sanji"
db_password = "여기에-강력한-비밀번호-입력" # 필수. 노출 주의

# --- EC2 ---
# SSH 키페어가 있으면 이름을 넣고, 없으면 비워두세요. (SSM으로 접속 가능)
ec2_key_name = ""

# --- CI/CD ---
github_repo = "BankRupang/san-ji-jik-kyeng"

# --- HTTPS (선택) ---
# ACM 인증서를 발급했다면 ARN을 넣으면 443 리스너가 자동 생성됩니다.
# acm_certificate_arn = "arn:aws:acm:ap-northeast-2:123456789012:certificate/xxxx"

# --- 알람 (선택) ---
# alert_email = "your-email@example.com"

# --- Windows에서 로컬 실행 시 ---
# CI/CD(Linux)에서는 기본값(/bin/bash)을 그대로 씁니다.
# Windows에서 terraform apply를 직접 실행한다면 Git Bash 경로로 채우세요.
# bash_path = "C:/Program Files/Git/bin/bash.exe"
