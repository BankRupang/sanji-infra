# ============================================================================
# prod 환경 변수 값 예시 파일
# ============================================================================
# 사용법:
#   1) 이 파일을 terraform.tfvars 라는 이름으로 복사합니다.
#        cp terraform.tfvars.example terraform.tfvars
#   2) 아래 값을 우리 환경에 맞게 채웁니다.
#   3) terraform.tfvars 는 비밀번호가 들어가므로 git에 올리지 않습니다.
#      (.gitignore가 *.tfvars 를 이미 제외하고 있습니다. 이 .example만 추적됩니다.)

# --- 공통 ---
project     = "sanji"
environment = "prod"
aws_region  = "ap-northeast-2"

# --- 네트워크 ---
# Grafana/SSH 접근을 허용할 본인 공인 IP로 꼭 좁히세요. (예: "1.2.3.4/32")
admin_cidr = "211.198.249.94/32"

# --- 데이터베이스 (필수) ---
db_name     = "sanji"
db_username = "sanji"
db_password = "sanji-database-password-q1w2e3r4" # 필수. 노출 주의

# --- EC2 ---
kafka_count              = 3
kafka_instance_type      = "t3.medium"
kafka_volume_size        = 30
monitoring_instance_type = "t3.medium"
monitoring_volume_size   = 50

# SSH 키페어가 있으면 이름을 넣고, 없으면 비워두세요(SSM으로 접속 가능).
ec2_key_name = ""

# --- Bid 오토스케일링 ---
bid_min_capacity = 2
bid_max_capacity = 6

# --- CI/CD ---
github_repo = "BankRupang/san-ji-jik-kyeng"

# --- HTTPS (선택) ---
# ACM 인증서를 발급했다면 ARN을 넣으면 443 리스너가 자동 생성됩니다.
# acm_certificate_arn = "arn:aws:acm:ap-northeast-2:123456789012:certificate/xxxx"

# --- 알람 (선택) ---
alert_email = "qkrwns1478@gmail.com"
